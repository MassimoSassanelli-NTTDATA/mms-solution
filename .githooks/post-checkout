#!/bin/sh

# post-checkout receives:
#   $1 previous HEAD
#   $2 new HEAD
#   $3 1 if branch checkout, 0 if file checkout
if [ "$3" != "1" ]; then
  exit 0
fi

repo_root="$(git rev-parse --show-toplevel 2>/dev/null)"
if [ -z "$repo_root" ]; then
  exit 0
fi

if command -v pwsh >/dev/null 2>&1; then
  ps="pwsh"
elif command -v powershell >/dev/null 2>&1; then
  ps="powershell"
else
  echo "post-checkout: PowerShell not found, skipped syncing subrepo skills and workspace context." >&2
  exit 0
fi

"$ps" -NoProfile -ExecutionPolicy Bypass -File "$repo_root/scripts/sync-subrepo-skills.ps1" -Quiet
"$ps" -NoProfile -ExecutionPolicy Bypass -File "$repo_root/scripts/generate-workspace-context.ps1" -RepoRoot "$repo_root" -Quiet -SkipValidation
